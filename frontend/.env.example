# Frontend environment variables
# Copy this to frontend/.env for local development
# In production these are injected by GitHub Actions secrets

# Backend API URL
# Local:      http://localhost:8000
# Production: https://bianca-backend-n4tovjvkha-uc.a.run.app
VITE_API_BASE_URL=http://localhost:8000

# Google OAuth client ID (Web Application type)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
