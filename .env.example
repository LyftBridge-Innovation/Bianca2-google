# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_WEB_CLIENT_ID=your_google_oauth_client_id
GOOGLE_WEB_CLIENT_SECRET=your_google_oauth_client_secret

# ── Google APIs ───────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key

# ── Firebase / Firestore ──────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_gcp_project_id
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
FIREBASE_DATABASE_NAME=your_firestore_database_name
GOOGLE_APPLICATION_CREDENTIALS=firebase-credentials.json

# ── Vertex AI ─────────────────────────────────────────────────────────────────
VERTEX_PROJECT_ID=your_gcp_project_id
VERTEX_LOCATION=global
VERTEX_DATASTORE_ID=your_vertex_datastore_id

# ── Anthropic ─────────────────────────────────────────────────────────────────
# On Cloud Run this is injected from Secret Manager — only needed locally
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Google Cloud / Cloud Run ──────────────────────────────────────────────────
GCP_PROJECT_ID=your_gcp_project_id
GMAIL_PUBSUB_TOPIC=projects/your_gcp_project_id/topics/gmail-push

# ── Twilio (phone voice integration) ─────────────────────────────────────────
# Found at: https://console.twilio.com → Account Info
# TWILIO_AUTH_TOKEN is stored in Secret Manager on Cloud Run — only needed locally
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# ── Assistant identity ────────────────────────────────────────────────────────
ASSISTANT_NAME=Bianca

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Only needed for local frontend dev — production uses GitHub Actions secrets
VITE_API_BASE_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
